<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<title>🎫 티켓 뷰 설치</title>
<style>
  body{font-family:-apple-system,sans-serif;max-width:600px;margin:40px auto;padding:0 20px;background:#f8f9fa;color:#333;}
  .card{background:#fff;border-radius:12px;padding:24px;margin-bottom:16px;box-shadow:0 2px 8px rgba(0,0,0,0.08);}
  h1{font-size:22px;margin:0 0 4px;} .sub{color:#666;font-size:14px;margin-bottom:20px;}
  .bookmark-btn{display:inline-block;padding:12px 24px;background:#0a7d72;color:#fff;border-radius:8px;font-size:15px;font-weight:600;text-decoration:none;cursor:grab;}
  .drag-hint{font-size:13px;color:#888;margin-top:8px;}
  .step{display:flex;gap:12px;align-items:flex-start;margin-bottom:10px;font-size:14px;}
  .num{background:#0a7d72;color:#fff;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;margin-top:1px;}
  .code-box{background:#f1f3f5;border-radius:6px;padding:12px;font-size:11px;word-break:break-all;font-family:monospace;max-height:80px;overflow:auto;margin-top:12px;}
  .copy-manual{margin-top:8px;} .copy-manual button{padding:6px 14px;background:#059669;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:13px;}
  h2{font-size:15px;margin:0 0 12px;}
  .warn{background:#fff3cd;border-radius:6px;padding:10px 12px;font-size:13px;color:#856404;margin-bottom:12px;}
  .feat{background:#e6f7f4;border-radius:6px;padding:10px 12px;font-size:13px;color:#0a5d54;margin-bottom:12px;}
  .fix-list{font-size:13px;color:#555;padding-left:18px;margin:0;} .fix-list li{margin-bottom:4px;}
  .tag-r{display:inline-block;background:#0a7d72;color:#fff;font-size:11px;padding:1px 6px;border-radius:4px;margin-right:4px;}
</style>
</head>
<body>
<div class="card">
  <h1>🎫 티켓 뷰</h1>
  <p class="sub">젠데스크 티켓 → 슬랙 적재 텍스트 + 답변 초안 자동 생성</p>
  <div class="step"><div class="num">1</div><p>아래 버튼을 북마크바로 <strong>드래그</strong>하세요</p></div>
  <div class="step"><div class="num">2</div>
    <div><a href="#" class="bookmark-btn">🎫 티켓 뷰</a>
    <div class="drag-hint">↑ 이 버튼을 북마크바로 끌어다 놓으세요</div></div>
  </div>
  <div class="step"><div class="num">3</div><p>젠데스크 티켓 화면에서 북마크를 클릭하면 팝업이 열립니다</p></div>
</div>

<div class="card">
  <h2><span class="tag-r">NEW</span> 케이스 감지 로직 고도화</h2>
  <div class="feat">단순 포함 여부가 아닌 <strong>키워드 출현 빈도수 기반 스캔</strong>이 적용되었습니다. 고객이 남긴 모든 메시지를 하나로 병합한 후, 특정 키워드를 얼마나 자주 언급했는지 가중치를 더해 가장 정확도 높은 케이스를 자동으로 매칭합니다.</div>
  <ul class="fix-list">
    <li>케이스 자동 감지: 요금정정 · 통행료 · 취소/미탑승 수수료 · 분실물 · 영업손실비 · 카시트 · 드라이버 클레임 등</li>
    <li>확인이 필요한 수치는 <strong>[   ]</strong> 자리표로 비워둠 → 어드민 확인 후 채워서 발송</li>
    <li>초안은 수정 가능하며 <strong>📋 초안 복사</strong>로 바로 붙여넣기</li>
    <li>Claude 생성을 쓰려면 코드 내 <code>DRAFT_PROXY_URL</code>에 주소 입력 (비워두면 템플릿 초안 사용)</li>
  </ul>
  <div class="warn">⚠ 초안은 발송 전 반드시 검토하세요. 영구 차단·보상 약속은 처리 가능한 케이스인지 확인 후 사용하세요.</div>
</div>

<div class="card">
  <h2>버튼이 드래그가 안 되면</h2>
  <p style="font-size:13px;color:#555;margin:0 0 8px;">아래 코드를 복사해 북마크를 새로 만들고 URL 칸에 붙여넣으세요.</p>
  <div class="code-box" id="codeBox"></div>
  <div class="copy-manual"><button onclick="copyCode()">📋 코드 복사</button></div>
</div>

<script>
// =========================================================================
// 북마크릿 실제 작동 코드 (수정 및 유지보수는 여기서 하시면 됩니다)
// =========================================================================
async function runBookmarklet() {
  const urlMatch=location.href.match(/zendesk\.com\/agent\/tickets\/(\d+)/);
  if(!urlMatch){alert('젠데스크 티켓 페이지에서 실행해주세요.');return;}
  const ticketNum=urlMatch[1];
  const ticketUrl=`https://tadatadahelp.zendesk.com/agent/tickets/${ticketNum}`;

  // 이미 팝업 열려있으면 닫고 재실행 (중복 방지)
  const existing=document.getElementById('zd_overlay_'+ticketNum);
  if(existing){existing.remove();}

  // DOM이 현재 티켓으로 업데이트됐는지 확인
  const isDomReady=()=>document.body.innerText.includes('#'+ticketNum);
  if(!isDomReady()){
    alert('⏳ 티켓 로딩 중이거나 다른 탭이에요!\n현재 티켓(#'+ticketNum+') 화면에서 잠시 후 다시 눌러주세요.');
    return;
  }

  function blinkTitle(msg){
    const old=document.title;
    document.title=msg;
    setTimeout(()=>document.title=old,1200);
  }

  // ── 고객 메시지 추출 ──
  let customerMsg='';
  let customerMsgs=[]; // 고객이 여러 번 인입한 경우 모두 수집
  try{
    const bodyText=document.body.innerText;
    const bodyLimit=bodyText.indexOf('메시지 작성기');

    let activeConv=null;
    const allConvs=[...document.querySelectorAll('[data-test-id="ticket-main-conversation"]')];
    if(allConvs.length===0){
      allConvs.push(...document.querySelectorAll('[class*="conversation"]'));
    }
    for(const c of allConvs){
      const r=c.getBoundingClientRect();
      const st=getComputedStyle(c);
      const isVisible=r.width>0&&r.height>0&&st.visibility!=='hidden'&&st.display!=='none';
      const hasContent=(c.innerText||'').trim().length>5;
      if(isVisible&&hasContent){activeConv=c;break;}
    }
    const convEl=activeConv
      ||document.querySelector('[data-test-id="ticket-main-conversation"]')
      ||document.querySelector('[class*="conversation"]')
      ||document.querySelector('main')
      ||document.body;

    const scopedComments=(convEl&&convEl.querySelectorAll('.zd-comment').length>0)
      ?convEl.querySelectorAll('.zd-comment')
      :document.querySelectorAll('.zd-comment');

    const isMessaging = !!(convEl && /Web User [a-f0-9]+/.test(convEl.innerText));
    if(isMessaging){
      const rawLines=convEl.innerText.split('\n');
      const cutLineIdx=rawLines.findIndex(l=>l.trim()==='메시지 작성기');
      const allLines=cutLineIdx>=0?rawLines.slice(0,cutLineIdx):rawLines;

      let lastAgentIdx=-1;
      for(let k=0;k<allLines.length;k++){
        if(allLines[k].trim()==='드라이버 상담사') lastAgentIdx=k;
      }
      const scanFrom=0; void lastAgentIdx;

      const isNoise=(ml)=>(
        !ml||ml==='•'||ml==='A form was sent:'||ml==='내부'||
        ml==='드라이버 상담사'||/^TADA /.test(ml)||/^Web User [a-f0-9]/.test(ml)||
        ml==='대화'||/님과의 대화$/.test(ml)||/^메시징을 통해$|^웹 양식을 통해$|^이메일을 통해$|^전화를 통해$|^티켓 요약 보기$|^대화 로그$/.test(ml)||
        /^(오늘|어제|그제|월요일|화요일|수요일|목요일|금요일|토요일|일요일) \d{1,2}:\d{2}$/.test(ml)||
        /^\d{1,2}:\d{2}$/.test(ml)||
        /^메시지 작성기$|^메시징$|^보내기$/.test(ml)||
        /^존함을 말씀|^필요시 추가확인|^사진 또는 자료/.test(ml)||
        /^상담 중인 날짜|^감사합니다|^오늘도 안전/.test(ml)||
        /^\d{4}-\d{2}-\d{2}$|^\d{2}-\d{2}$/.test(ml)||
        /^오류 제보|^유선 상담 중 자료|^계약 및 해지|^기타$/.test(ml)||
        /^\d{10,11}$/.test(ml)||
        /^\d{3,4}-\d{3,4}-\d{4}$/.test(ml)
      );

      const blocks=[];
      let i=scanFrom;
      while(i<allLines.length){
        const l=allLines[i].trim();
        if(/^Web User [a-f0-9]/.test(l)){
          let j=i+1;
          const msgLines=[];
          while(j<allLines.length){
            const ml=allLines[j].trim();
            if(ml==='드라이버 상담사'||/^TADA /.test(ml)||/^Web User [a-f0-9]/.test(ml)) break;
            if(ml==='메시지 작성기') break;
            if(!isNoise(ml)) msgLines.push(ml);
            j++;
          }
          if(msgLines.length>0) blocks.push(msgLines.join('\n'));
          i=j;
        }else{
          i++;
        }
      }
      if(blocks.length>0){
        customerMsgs=blocks.map(b=>b.trim()).filter(b=>b.length>0);
        customerMsg=customerMsgs.length>0?customerMsgs[customerMsgs.length-1]:'';
      }
    }

    if(!customerMsg){
      const bubbleSelectors=[
        '[data-test-id*="message"][class*="end"]',
        '[class*="message-bubble"]',
        '[class*="chat-bubble"]',
      ];
      const _scope=convEl||document;
      for(const sel of bubbleSelectors){
        const bubbles=_scope.querySelectorAll(sel);
        if(bubbles.length>0){
          const texts=[...bubbles].map(b=>b.innerText?.trim()).filter(Boolean);
          if(texts.length>0){customerMsg=texts[texts.length-1];break;}
        }
      }
    }

    if(!customerMsg&&convEl){
      const fullT=convEl.innerText||'';
      const webUserBlocks=fullT.split(/Web User [a-f0-9]+\n•\n/);
      if(webUserBlocks.length>1){
        const lastBlock=webUserBlocks[webUserBlocks.length-1];
        const msgLines=lastBlock.split('\n');
        const msgContent=[];
        for(const line of msgLines){
          if(/^오늘 \d|^어제 \d|^드라이버|^TADA|^사진 또는|^상담 중인|^감사합니다|^오늘도/.test(line.trim())) break;
          const l=line.trim();
          if(!l||/^\d{1,2}:\d{2}$/.test(l)) continue;
          if(l==='기타'||l==='오류 제보 하기'||l==='대화'||/님과의 대화$/.test(l)) continue;
          if(/^메시징을 통해$|^웹 양식을 통해$|^이메일을 통해$|^전화를 통해$|^티켓 요약 보기$|^대화 로그$/.test(l)) continue;
          msgContent.push(l);
        }
        const _m=msgContent.join('\n').trim();
        if(_m.length>0) customerMsg=_m;
      }
    }

    if(!customerMsg && !isMessaging){
      const comments=scopedComments;
      for(let i=0;i<comments.length;i++){
        const _box=comments[i].closest('article, li, [data-comment-id], [class*="event"]')||comments[i].parentElement;
        const _boxTxt=_box?_box.innerText:'';
        const _author=(_boxTxt.split('\n').map(x=>x.trim()).filter(Boolean)[0])||'';
        if(/^TADA\b/.test(_author)||/(^|\n)\s*내부\s*(\n|$)/.test(_boxTxt)) continue;
        const tmp=document.createElement('div');
        tmp.innerHTML=comments[i].innerHTML;
        let rawTxt=tmp.innerText||tmp.textContent||'';
        if(/전화구분\s*[:：]|통화시간\s*[:：]|발신내선\s*[:：]|수신번호\s*[:：]/.test(rawTxt)){continue;}
        const origMailIdx=rawTxt.search(/-{2,}\s*원본 메일|원본 메일\s*-{2,}|-{3,}\s*Original/);
        if(origMailIdx>=0) rawTxt=rawTxt.slice(0,origMailIdx);
        if(bodyLimit>=0){
          const commentPosInBody=bodyText.indexOf(rawTxt.slice(0,20).trim());
          if(commentPosInBody>=0&&commentPosInBody>bodyLimit) continue;
        }
        if(/타다 팀 드림|타다를 이용해 주셔서|이용 경험 평가하기|안녕하세요\.\s*[가-힣]+님\s*타다/.test(rawTxt)){
          continue;
        }
        const cutIdx=rawTxt.indexOf('메시지 작성기');
        const txt=cutIdx>=0?rawTxt.slice(0,cutIdx):rawTxt;
        const lines=txt.split('\n').map(l=>l.trim()).filter(l=>{
          if(!l) return false;
          if(/^https?:\/\//.test(l)) return false;
          if(/^\d{4}\.\d{2}\.\d{2}( \d{1,2}:\d{2}(:\d{2})?)?$/.test(l)) return false;
          if(/^(오늘|어제|그제) \d{1,2}:\d{2}$/.test(l)) return false;
          if(/^\d+분 전$/.test(l)||/^\d+시간 전$/.test(l)) return false;
          if(/^\d{1,2}:\d{2}$/.test(l)) return false;
          if(/\.(png|jpg|jpeg|gif|pdf)$/i.test(l)) return false;
          if(l==='·'||l==='•'||l==='-') return false;
          if(/^수신자:$|^자세히 보기$|^원본 메일|^-{3,}/.test(l)) return false;
          if(/^메시지 작성기$|^메시징$|^보내기$|^사진 또는 자료|^상담 중인 날짜/.test(l)) return false;
          if(l==='대화'||/님과의 대화$/.test(l)||/^메시징을 통해$|^웹 양식을 통해$|^이메일을 통해$|^전화를 통해$|^티켓 요약 보기$|^대화 로그$/.test(l)) return false;
          if(l==='기타'||l==='오류 제보 하기'||/^타다에 전달 하고 싶은/.test(l)||/^이외 문의를 남겨주시면/.test(l)) return false;
          return true;
        });
        if(lines.length>0){
          const msg=lines.join('\n').replace(/[ \t]+/g,' ').replace(/\n{3,}/g,'\n\n').trim();
          if(msg.length>0) customerMsgs.push(msg);
        }
      }
      if(customerMsgs.length>0) customerMsg=customerMsgs[0];
    }

    if(!customerMsg) customerMsg='(내용을 직접 입력해주세요)';
  }catch(e){customerMsg='(내용 파싱 실패 - 직접 입력해주세요)';}

  // ── 케이스 자동 감지 ──
  const CASE_RULES=[
    {key:'통행료',     label:'통행료',       keywords:['통행료','톨','고속도로','유료도로','하이패스','우면산','의왕','영종','인천대교']},
    {key:'요금정정',   label:'요금 정정',    keywords:['요금','결제','정정','두배','과다','경로 우회','우회','gps','비싸','금액','더 나왔']},
    {key:'분실물',     label:'분실물',       keywords:['분실','잃어','두고','놓고','가방','지갑','폰','핸드폰','이어폰','우산']},
    {key:'영업손비',     label:'영업손실비',   keywords:['오염','토했','구토','세차','냄새','오물','더럽','카시트 오염']},
    {key:'예약취소',   label:'예약 취소(드라이버 귀책)', keywords:['차량이 안','차가 안','안 왔','안왔','못 왔','못왔','오지 않','자다','늦게 온','30분 후','전화를 안 받','전화를 아무리','연락이 안','노쇼','드라이버가 안','기사님이 안','배차 취소','예약이 취소','갑자기 취소','자기가 자다']},
    {key:'취소수수료', label:'취소 수수료',  keywords:['취소수수료','취소 수수료','취소비']},
    {key:'미탑승',     label:'미탑승 수수료',keywords:['미탑승','no show']},
    {key:'카시트',     label:'카시트',       keywords:['카시트','아기','영아','유아','이너시트','신생아']},
    {key:'드라이버',   label:'드라이버',     keywords:['기사님','드라이버','불친절','위험','난폭','욕설','사고']},
    {key:'앱오류',     label:'앱 오류',      keywords:['오류','버그','안돼','작동','error','앱 문제','접속']},
    {key:'일반문의',   label:'일반 문의',    keywords:[]}
  ];

  // ==== 빈도수 기반 케이스 자동 감지 로직 적용 ====
  const allCustomerTexts = customerMsgs.length > 0 ? customerMsgs.join('\n') : (customerMsg || '');
  const msgCtx = allCustomerTexts.toLowerCase();
  const bodyCtx = (document.body.innerText || '').toLowerCase();

  let detectedCase = CASE_RULES[CASE_RULES.length - 1]; // 기본: 일반 문의
  let bestScore = 0;

  CASE_RULES.slice(0, -1).forEach(rule => {
    let s = 0;
    rule.keywords.forEach(kw => {
      const keyword = kw.toLowerCase();
      // 고객이 여러 번 남긴 전체 발화에서 해당 키워드가 등장한 총 횟수를 측정
      const matchCount = msgCtx.split(keyword).length - 1;
      
      if (matchCount > 0) {
        // 출현 빈도수에 비례하여 가중치(+2)를 누적하여 판별 정확도 상승
        s += (matchCount * 2);
      } else if (bodyCtx.includes(keyword)) {
        // 발화에는 없지만 화면 다른 곳에 있다면 단순 노이즈일 가능성이 커 가중치 +1 부여
        s += 1;
      }
    });
    // 가장 높은 점수를 획득한 케이스를 최종 채택
    if (s > bestScore) {
      bestScore = s;
      detectedCase = rule;
    }
  });

  // ── UI ──
  const overlay=document.createElement('div');
  overlay.id='zd_overlay_'+ticketNum;
  overlay.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.5);display:flex;justify-content:center;align-items:center;z-index:999999;';
  const box=document.createElement('div');
  box.style.cssText='background:#fff;padding:20px;border-radius:12px;width:580px;max-height:90vh;overflow-y:auto;font-family:sans-serif;box-shadow:0 4px 20px rgba(0,0,0,0.3);';
  box.innerHTML=`
    <h3 style='margin:0 0 12px;padding-bottom:10px;border-bottom:1px solid #eee;font-size:15px;'>
      🎫 젠데스크 적재 — <span style='color:#0052cc;'>#${ticketNum}</span>
      <span style='font-size:11px;background:#eff6ff;color:#1d4ed8;padding:2px 8px;border-radius:10px;margin-left:8px;font-weight:normal;'>${detectedCase.label}</span>
    </h3>
    <div style='margin-bottom:12px;'>
      <label style='display:block;font-weight:bold;margin-bottom:7px;font-size:13px;'>인입 주체:</label>
      <div style='display:flex;gap:8px;'>
